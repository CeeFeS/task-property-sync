{
  "name": "task-property-plugin",
  "version": "1.0.0",
  "description": "Obsidian plugin that syncs Tasks plugin properties to frontmatter properties",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/"
  },
  "keywords": [
    "obsidian",
    "tasks",
    "properties",
    "frontmatter"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@typescript-eslint/parser": "^8.57.1",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.9.3"
  }
}
